# NewsoBet Africa Production Environment Variables

# Server Configuration
PORT=5000
NODE_ENV=production

# Security Configuration
JWT_SECRET=newsbet_production_secret_make_this_long_and_random_xyz123
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS Configuration
FRONTEND_URL=https://newsbet.rpnmore.com
PRODUCTION_URL=https://newsbet.rpnmore.com

# API Keys
GEMINI_API_KEY=your_actual_gemini_api_key_here

# Mobile Money API Keys (for future integrations)
MTN_API_KEY=your_mtn_api_key
AIRTEL_API_KEY=your_airtel_api_key
VODAFONE_API_KEY=your_vodafone_api_key
TIGO_API_KEY=your_tigo_api_key

# Database Configuration (for future use)
DATABASE_URL=postgresql://user:password@localhost:5432/newsbet

# Redis Configuration (for future use)
REDIS_URL=redis://localhost:6379